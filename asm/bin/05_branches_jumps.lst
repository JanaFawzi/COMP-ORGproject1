 148      
 149          # From 0x0200, the target at 0x0400 is exactly PC+2+510.
 150      .org 0x0200
 151      jump_plus510_source:
 152          j jump_boundary_target
 153      
 154      .org 0x0400
 155      jump_boundary_target:
 156          addi x5, 1
