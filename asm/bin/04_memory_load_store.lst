  12          # SW/LW use little-endian 16-bit words.
  13          li16 x4, 0xABCD
  14          sw x4, 0(x3)
  15          lw x5, 0(x3)
  16          beq x5, x4, word_ok
  17          j word_fail
  18      word_ok:
