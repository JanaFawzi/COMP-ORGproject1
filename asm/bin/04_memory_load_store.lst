  47      
  48          # Odd-address SW must not change either byte.
  49          li x4, 0x11
  50          sb x4, 3(x3)
  51          li x4, 0x22
  52          sb x4, 4(x3)
  53          mv x5, x3
  54          addi x5, 3
  55          li16 x4, 0xBEEF
