  60          j align_fail
  61      odd_low_ok:
  62          lbu x4, 1(x5)
  63          li x0, 0x22
  64          beq x4, x0, odd_store_ok
  65          j align_fail
  66      odd_store_ok:
  67      
  68          # Odd-address LW must leave its destination unchanged.
  69          li16 x4, 0xCAFE
  70          lw x4, 0(x5)
  71          li16 x0, 0xCAFE
  72          beq x4, x0, align_ok
  73          j align_fail
