  31      
  32          # LB sign-extends 0x80. LBU zero-extends 0x80.
  33          li16 x4, 0x0080
  34          sb x4, 2(x3)
  35          lb x5, 2(x3)
  36          li16 x4, 0xFF80
  37          beq x5, x4, lb_ok
