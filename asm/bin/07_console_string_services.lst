  87      input_buffer:      .space 8
  88      title:             .string "TEST 07 - CONSOLE STRING SERVICES\n"
  89      boundary_text:     .string "PRINT INT BOUNDARIES: "
  90      boundary_pass:     .string "PRINT INT 0X7FFF AND 0X8000: PASS\n"
  91      char_text:         .string "PRINT CHAR SAMPLE: "
