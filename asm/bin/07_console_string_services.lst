ZX16 Assembler Listing
==================================================

   1      # Test 07: console and string services
   2      # It exercises print/read integer, character, and string ECALLs.
   3      
   4      .text
   5      
   6      start:
   7          li16 a0, title
   8          ecall 0x012
   9      
  10          # print_int treats 0x7FFF as 32767 and 0x8000 as -32768.
  11          li16 a0, boundary_text
  12          ecall 0x012
  13          li16 a0, 0x7FFF
  14          ecall 0x000
  15          li a0, 32
  16          ecall 0x001
  17          li16 a0, 0x8000
  18          ecall 0x000
  19          li a0, 10
  20          ecall 0x001
  21          li16 a0, boundary_pass
  22          ecall 0x012
  23      
  24          # print_char emits the low byte of a0.
  25          li16 a0, char_text
  26          ecall 0x012
  27          li a0, 'Z'
  28          ecall 0x001
  29          li a0, 'X'
  30          ecall 0x001
  31          li a0, '1'
  32          ecall 0x001
  33          li a0, '6'
  34          ecall 0x001
  35          li a0, 10
  36          ecall 0x001
  37          li16 a0, char_pass
  38          ecall 0x012
  39      
  40          # print_string walks bytes until the zero terminator.
  41          li16 a0, sample_string
  42          ecall 0x012
  43          li16 a0, string_pass
  44          ecall 0x012
  45      
  46          # With the GUI assembly runner there is no scripted input, so read_int
  47          # should return zero when no digits are available.
  48          ecall 0x011
  49          li x3, 0
  50          beq a0, x3, read_int_ok
  51          j read_int_fail
  52      read_int_ok:
  53          li16 a0, read_int_pass
  54          ecall 0x012
  55      
  56          # read_string at EOF writes a terminator and reports length zero.
  57          li16 a0, input_buffer
  58          li a1, 8
  59          ecall 0x010
  60          li x3, 0
  61          beq a0, x3, read_len_ok
  62          j read_string_fail
  63      read_len_ok:
  64          li16 x4, input_buffer
  65          lbu x5, 0(x4)
  66          li x3, 0
  67          beq x5, x3, read_string_ok
  68          j read_string_fail
  69      read_string_ok:
  70          li16 a0, read_string_pass
  71          ecall 0x012
  72      
  73          li16 a0, all_pass
  74          ecall 0x012
  75          ecall 0x3FF
  76      
  77      read_int_fail:
  78          li16 a0, read_int_bad
  79          ecall 0x012
  80          ecall 0x3FF
  81      read_string_fail:
  82          li16 a0, read_string_bad
  83          ecall 0x012
  84          ecall 0x3FF
  85      
