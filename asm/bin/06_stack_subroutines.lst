ZX16 Assembler Listing
==================================================

   1      # Test 06: stack and subroutines
   2      # It checks stack reset, PUSH/POP, CALL/RET, and nested calls.
   3      
   4      .text
   5      
   6      start:
   7          li16 a0, title
   8          ecall 0x012
   9      
  10          # The project stack starts below graphics memory at 0xEFFE.
  11          li16 x3, 0xEFFE
  12          beq sp, x3, reset_ok
  13          j reset_fail
  14      reset_ok:
  15          # PUSH moves down by two and POP restores the value and SP.
  16          li16 x3, 0x1234
  17          push x3
  18          li16 x4, 0xEFFC
  19          beq sp, x4, push_address_ok
  20          j stack_fail
  21      push_address_ok:
  22          lw x5, 0(sp)
  23          beq x5, x3, push_value_ok
  24          j stack_fail
  25      push_value_ok:
  26          li x5, 0
  27          pop x5
  28          beq x5, x3, pop_value_ok
  29          j stack_fail
  30      pop_value_ok:
  31          li16 x4, 0xEFFE
  32          beq sp, x4, stack_ok
  33          j stack_fail
  34      stack_ok:
  35          li16 a0, stack_pass
  36          ecall 0x012
  37      
  38          # A simple CALL adds two and RET comes back here.
  39          li x3, 5
  40          call add_two
  41      after_add_two:
  42          li x4, 7
  43          beq x3, x4, call_ok
  44          j call_fail
  45      call_ok:
  46          li16 a0, call_pass
  47          ecall 0x012
  48      
  49          # The outer function saves ra before making a nested CALL.
  50          li x3, 10
  51          call outer_function
  52      after_outer:
  53          li x4, 13
  54          beq x3, x4, nested_value_ok
  55          j nested_fail
  56      nested_value_ok:
  57          li16 x4, 0xEFFE
  58          beq sp, x4, nested_ok
  59          j nested_fail
  60      nested_ok:
  61          li16 a0, nested_pass
  62          ecall 0x012
  63      
  64          # The empty stack returns to 0xEFFE, below the graphics region.
  65          li16 x4, 0xEFFE
  66          beq sp, x4, safe_sp_ok
  67          j safe_fail
  68      safe_sp_ok:
  69          li16 x4, 0xF000
  70          lbu x5, 0(x4)
  71          li x0, 0
  72          beq x5, x0, safe_ok
  73          j safe_fail
  74      safe_ok:
  75          li16 a0, safe_pass
  76          ecall 0x012
  77      
  78          li16 a0, all_pass
  79          ecall 0x012
  80          ecall 0x3FF
  81      
  82      add_two:
  83          addi x3, 2
  84          li16 x4, after_add_two
  85          beq ra, x4, add_two_return_ok
  86          j call_fail
  87      add_two_return_ok:
  88          ret
  89      
  90      outer_function:
  91          push ra
  92          addi x3, 1
  93          call inner_function
  94          pop ra
  95          ret
  96      
  97      inner_function:
  98          addi x3, 2
  99          ret
 100      
