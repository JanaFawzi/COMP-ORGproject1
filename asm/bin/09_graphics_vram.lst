ZX16 Assembler Listing
==================================================

   1      # Test 09: graphics VRAM
   2      # It checks tile map, tile definitions, palette bytes, nibbles, and RGB332 math.
   3      
   4      .text
   5      
   6      start:
   7          li16 a0, title
   8          ecall 0x012
   9      
  10          # Tile map covers 20x15 cells from 0xF000 through 0xF12B.
  11          li16 x3, 0xF000
  12          li x4, 1
  13          sb x4, 0(x3)
  14          lbu x5, 0(x3)
  15          beq x5, x4, tile_first_ok
  16          j tile_map_fail
  17      tile_first_ok:
  18          li16 x3, 0xF128
  19          li x4, 15
  20          sb x4, 3(x3)
  21          lbu x5, 3(x3)
  22          beq x5, x4, tile_map_ok
  23          j tile_map_fail
  24      tile_map_ok:
  25          li16 a0, tile_map_pass
  26          ecall 0x012
  27      
  28          # Tile 0 starts at 0xF200, tile 15 ends at 0xF9FF.
  29          li16 x3, 0xF200
  30          li16 x4, 0x0021
  31          sb x4, 0(x3)
  32          lbu x5, 0(x3)
  33          beq x5, x4, tile_def_first_ok
  34          j tile_def_fail
  35      tile_def_first_ok:
  36          li16 x3, 0xF9F8
  37          li16 x4, 0x00AB
  38          sb x4, 7(x3)
  39          lbu x5, 7(x3)
  40          beq x5, x4, tile_def_ok
  41          j tile_def_fail
  42      tile_def_ok:
  43          li16 a0, tile_def_pass
  44          ecall 0x012
  45      
  46          # In one tile byte, even x uses the low nibble and odd x uses the high nibble.
  47          li16 x3, 0xF200
  48          lbu x4, 0(x3)
  49          mv x5, x4
  50          andi x5, 0x0F
  51          li x0, 1
  52          beq x5, x0, low_nibble_ok
  53          j nibble_fail
  54      low_nibble_ok:
  55          srli x4, 4
  56          andi x4, 0x0F
  57          li x0, 2
  58          beq x4, x0, nibble_ok
  59          j nibble_fail
  60      nibble_ok:
  61          li16 a0, nibble_pass
  62          ecall 0x012
  63      
  64          # Palette is 16 RGB332 bytes at 0xFA00 through 0xFA0F.
  65          li16 x3, 0xFA00
  66          li16 x4, 0x00E3
  67          sb x4, 0(x3)
  68          lbu x5, 0(x3)
  69          beq x5, x4, palette_first_ok
  70          j palette_fail
  71      palette_first_ok:
  72          li16 x3, 0xFA08
  73          li16 x4, 0x001C
  74          sb x4, 7(x3)
  75          lbu x5, 7(x3)
  76          beq x5, x4, palette_ok
  77          j palette_fail
  78      palette_ok:
  79          li16 a0, palette_pass
  80          ecall 0x012
  81      
  82          # RGB332 full-intensity channels expand to 0xFF.
  83          li x3, 7
  84          mv x4, x3
  85          slli x3, 5
  86          slli x4, 2
  87          or x3, x4
  88          li x4, 7
  89          srli x4, 1
  90          or x3, x4
  91          li16 x4, 0x00FF
  92          beq x3, x4, red_expand_ok
  93          j rgb_fail
  94      red_expand_ok:
  95          li x3, 3
  96          mv x4, x3
  97          slli x3, 6
  98          slli x4, 4
  99          or x3, x4
 100          li x4, 3
 101          slli x4, 2
 102          or x3, x4
 103          li x4, 3
 104          or x3, x4
 105          li16 x4, 0x00FF
 106          beq x3, x4, rgb_ok
 107          j rgb_fail
 108      rgb_ok:
 109          li16 a0, rgb_pass
 110          ecall 0x012
