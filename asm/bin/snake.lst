ZX16 Assembler Listing
==================================================

   1      # ZX16 Snake
   2      # Controls: Up/Down/Left/Right or W/A/S/D
   3      # Tile map: 0xF000, 20 x 15
   4      # Tile IDs: 0 empty, 1 snake, 2 food, 3 wall
   5      
   6      .text
   7      
   8      start:
   9          li16 sp, 0xEFFE
  10      
  11          li a0, 35
  12          ecall 0x041
  13      
  14          # Palette
  15          li16 x3, 0xFA00
  16          li x4, 0x00
  17          sb x4, 0(x3)
  18          li x4, 0x1C
  19          sb x4, 1(x3)
  20          li x4, 0xE0
  21          sb x4, 2(x3)
  22          li x4, 0xFF
  23          sb x4, 3(x3)
  24      
  25          # Tile 0: empty
  26          li16 x3, 0xF200
  27          li16 x4, 128
  28          li x5, 0
  29      fill_tile0:
  30          sb x5, 0(x3)
  31          addi x3, 1
  32          dec x4
  33          bnz x4, fill_tile0
  34      
  35          # Tile 1: snake, full green block
  36          li16 x4, 128
  37          li x5, 0x11
  38      fill_tile1:
  39          sb x5, 0(x3)
  40          addi x3, 1
  41          dec x4
  42          bnz x4, fill_tile1
  43      
  44          # Tile 2: apple, smaller red center
  45          li16 x4, 128
  46          li x5, 0
  47      fill_tile2:
  48          sb x5, 0(x3)
  49          addi x3, 1
  50          dec x4
  51          bnz x4, fill_tile2
  52      
  53          li16 x3, 0xF304
  54          li x4, 8
  55          li x5, 0x22
  56      food_tile_rows:
  57          sb x5, -2(x3)
  58          sb x5, -1(x3)
  59          sb x5, 0(x3)
  60          sb x5, 1(x3)
  61          addi x3, 8
  62          dec x4
  63          bnz x4, food_tile_rows
  64      
  65          # Tile 3: wall
  66          li16 x3, 0xF380
  67          li16 x4, 128
  68          li x5, 0x33
  69      fill_tile3:
  70          sb x5, 0(x3)
  71          addi x3, 1
  72          dec x4
  73          bnz x4, fill_tile3
  74      
  75          # Clear map
  76          li16 x3, 0xF000
  77          li16 x4, 300
  78          li x5, 0
  79      clear_map:
  80          sb x5, 0(x3)
  81          addi x3, 1
  82          dec x4
  83          bnz x4, clear_map
  84      
  85          # Horizontal walls
  86          li16 x3, 0xF000
  87          li16 x6, 0xF118
  88          li x4, 20
  89          li x5, 3
  90      wall_top_bottom:
  91          sb x5, 0(x3)
  92          sb x5, 0(x6)
  93          addi x3, 1
  94          addi x6, 1
  95          dec x4
  96          bnz x4, wall_top_bottom
  97      
  98          # Vertical walls
  99          li16 x3, 0xF000
 100          li x4, 15
 101      wall_sides:
 102          sb x5, 0(x3)
 103          mv x6, x3
 104          addi x6, 19
 105          sb x5, 0(x6)
 106          addi x3, 20
 107          dec x4
 108          bnz x4, wall_sides
 109      
 110          # Initial body: offsets 148,149,150,151
 111          li16 x3, segments
 112          li16 x4, 148
 113          sw x4, 0(x3)
 114          li16 x4, 149
 115          sw x4, 2(x3)
 116          li16 x4, 150
 117          sw x4, 4(x3)
 118          li16 x4, 151
 119          sw x4, 6(x3)
 120      
 121          li16 x3, length
 122          li x4, 4
 123          sw x4, 0(x3)
 124      
 125          li16 x3, direction
 126          li x4, 1
 127          sw x4, 0(x3)
 128      
 129          li16 x3, next_food_offset
 130          li x4, 72
 131          sw x4, 0(x3)
 132      
 133          li16 x3, score
 134          li x4, 0
 135          sw x4, 0(x3)
 136      
 137          li16 x3, food0
 138          li16 x4, 170
 139          sw x4, 0(x3)
 140      
 141          li16 x3, food1
 142          li16 x4, 207
 143          sw x4, 0(x3)
 144      
 145          li16 x3, food2
 146          li16 x4, 228
 147          sw x4, 0(x3)
 148      
 149          # Initial draw. After this, wait for the first key press.
 150          li x4, 2
 151          li16 x3, 0xF0AA
 152          sb x4, 0(x3)
 153          li16 x3, 0xF0CF
 154          sb x4, 0(x3)
 155          li16 x3, 0xF0E4
 156          sb x4, 0(x3)
 157      
 158          li x4, 1
 159          li16 x3, 0xF094
 160          sb x4, 0(x3)
 161          sb x4, 1(x3)
 162          sb x4, 2(x3)
 163          sb x4, 3(x3)
 164      
 165      wait_for_start:
 166          ecall 0x030
 167          li x5, 1
 168          beq a0, x5, start_game
 169          li x5, 2
 170          beq a0, x5, start_game
 171          li x5, 3
 172          beq a0, x5, start_game
 173          li x5, 4
 174          beq a0, x5, start_game
 175          j wait_for_start
 176      
 177      start_game:
 178          j input_ready
 179      
 180      game_loop:
 181          li16 a0, 660
 182          li16 a1, 120
 183          ecall 0x040
 184      
 185          li16 x3, 3000
 186      delay_loop:
 187          dec x3
 188          bnz x3, delay_loop
 189      
 190          ecall 0x030
 191      
 192      input_ready:
 193          li x5, 1
 194          beq a0, x5, set_up
 195          j check_down
 196      set_up:
 197          li16 x3, direction
 198          lw x6, 0(x3)
 199          li x5, 20
 200          bne x6, x5, set_up_apply
 201          j direction_done
 202      set_up_apply:
 203          li x4, -20
 204          sw x4, 0(x3)
 205          j direction_done
 206      
 207      check_down:
 208          li x5, 2
 209          beq a0, x5, set_down
 210          j check_left
 211      set_down:
 212          li16 x3, direction
 213          lw x6, 0(x3)
 214          li x5, -20
 215          bne x6, x5, set_down_apply
 216          j direction_done
 217      set_down_apply:
 218          li x4, 20
 219          sw x4, 0(x3)
 220          j direction_done
 221      
 222      check_left:
 223          li x5, 3
 224          beq a0, x5, set_left
 225          j check_right
 226      set_left:
 227          li16 x3, direction
 228          lw x6, 0(x3)
 229          li x5, 1
 230          bne x6, x5, set_left_apply
 231          j direction_done
 232      set_left_apply:
 233          li x4, -1
 234          sw x4, 0(x3)
 235          j direction_done
 236      
 237      check_right:
 238          li x5, 4
 239          beq a0, x5, set_right
 240          j direction_done
 241      set_right:
 242          li16 x3, direction
 243          lw x6, 0(x3)
 244          li x5, -1
 245          bne x6, x5, set_right_apply
 246          j direction_done
 247      set_right_apply:
 248          li x4, 1
 249          sw x4, 0(x3)
 250      
 251      direction_done:
 252          # x4 = new head offset
 253          li16 x3, length
 254          lw x5, 0(x3)
 255          dec x5
 256          slli x5, 1
 257          li16 x3, segments
 258          add x3, x5
 259          lw x4, 0(x3)
 260      
 261          li16 x3, direction
 262          lw x5, 0(x3)
 263          add x4, x5
 264      
 265          li16 x3, pending_head
 266          sw x4, 0(x3)
 267      
 268          li16 x3, 0xF000
 269          add x3, x4
 270          lbu x5, 0(x3)
 271      
 272          li x6, 0
 273          bne x5, x6, check_food
 274          j normal_move
 275      
 276      check_food:
 277          li x6, 2
 278          bne x5, x6, check_snake
 279          j eat_food
 280      
 281      check_snake:
 282          li x6, 1
 283          beq x5, x6, snake_tile
 284          j game_over
 285      snake_tile:
 286          li16 x3, segments
 287          lw x6, 0(x3)
 288          beq x4, x6, tail_tile
 289          j game_over
 290      tail_tile:
 291          j normal_move
 292      
 293      normal_move:
 294          # Erase old tail.
 295          li16 x3, segments
 296          lw x4, 0(x3)
 297          li16 x3, 0xF000
 298          add x3, x4
 299          li x5, 0
 300          sb x5, 0(x3)
 301      
 302          # Shift body one slot toward the tail.
 303          li16 x3, length
 304          lw x5, 0(x3)
 305          dec x5
 306          li16 x3, segments
 307      shift_loop:
 308          mv x6, x3
 309          addi x6, 2
 310          lw a1, 0(x6)
 311          sw a1, 0(x3)
 312          addi x3, 2
 313          dec x5
 314          bnz x5, shift_loop
 315      
 316          # Store new head in the last slot.
 317          li16 x3, length
 318          lw x5, 0(x3)
 319          dec x5
 320          slli x5, 1
 321          li16 x3, segments
 322          add x3, x5
 323          li16 x4, pending_head
 324          lw x4, 0(x4)
 325          sw x4, 0(x3)
 326          j draw_head
 327      
 328      eat_food:
 329          # Append a new head and increase length, up to 24 cells.
 330          li16 x3, length
 331          lw x5, 0(x3)
 332          li x6, 24
 333          bltu x5, x6, grow_body
 334          j normal_move
 335      
 336      grow_body:
 337          mv x6, x5
 338          slli x6, 1
 339          li16 x3, segments
 340          add x3, x6
 341          li16 x4, pending_head
 342          lw x4, 0(x4)
 343          sw x4, 0(x3)
 344      
 345          inc x5
 346          li16 x3, length
 347          sw x5, 0(x3)
 348      
 349          li16 x3, score
 350          lw x5, 0(x3)
 351          inc x5
 352          sw x5, 0(x3)
 353      
 354          j draw_head_after_food
 355      
 356      draw_head:
 357          li16 x3, pending_head
 358          lw x4, 0(x3)
 359          li16 x3, 0xF000
 360          add x3, x4
 361          li x5, 1
 362          sb x5, 0(x3)
 363          j game_loop
 364      
 365      draw_head_after_food:
 366          li16 x3, pending_head
 367          lw x4, 0(x3)
 368          li16 x3, 0xF000
 369          add x3, x4
 370          li x5, 1
 371          sb x5, 0(x3)
 372          j food_next
 373      
 374      food_next:
 375          li16 x3, next_food_offset
 376          lw x4, 0(x3)
 377          addi x4, 37
 378      
 379          li16 x5, 280
 380          bltu x4, x5, food_next_try
 381          j food_wrap
 382      
 383      food_next_try:
 384          j food_try
 385      
 386      food_wrap:
 387          li x4, 42
 388      
 389      food_try:
 390          li x5, 20
 391          bltu x4, x5, food_try_advance
 392      
 393          li16 x5, 280
 394          bltu x4, x5, food_check_column
 395          j food_wrap
 396      
 397      food_try_advance:
 398          j food_advance
 399      
 400      food_check_column:
 401          mv x5, x4
 402      food_column_reduce:
 403          li x6, 20
 404          bltu x5, x6, food_column_ready
 405          addi x5, -20
 406          j food_column_reduce
 407      food_column_ready:
 408          li x6, 0
 409          beq x5, x6, food_advance
 410          li x6, 19
 411          beq x5, x6, food_advance
 412      
 413          li16 x3, 0xF000
 414          add x3, x4
 415          lbu x5, 0(x3)
 416          li x6, 0
 417          beq x5, x6, food_place
 418          j food_advance
 419      
 420      food_advance:
 421          addi x4, 37
 422          li16 x5, 280
 423          bltu x4, x5, food_advance_try
 424          j food_wrap
 425      
 426      food_advance_try:
 427          j food_try
 428      
 429      food_place:
 430          li16 x3, pending_head
 431          lw x5, 0(x3)
 432      
 433          li16 x3, food0
 434          lw x6, 0(x3)
 435          beq x5, x6, replace_food0
 436          j check_replace_food1
 437      
 438      replace_food0:
 439          sw x4, 0(x3)
 440          j save_next_food
 441      
 442      check_replace_food1:
 443          li16 x3, food1
 444          lw x6, 0(x3)
 445          beq x5, x6, replace_food1
 446          j replace_food2
 447      
 448      replace_food1:
 449          sw x4, 0(x3)
 450          j save_next_food
 451      
 452      replace_food2:
 453          li16 x3, food2
 454          sw x4, 0(x3)
 455      
 456      save_next_food:
 457          li16 x3, next_food_offset
 458          sw x4, 0(x3)
 459          li16 x3, 0xF000
 460          add x3, x4
 461          li x5, 2
 462          sb x5, 0(x3)
 463          j game_loop
 464      
 465      game_over:
 466          li16 a0, 180
 467          li16 a1, 700
 468          ecall 0x040
 469      
 470          li16 a0, game_over_text
 471          ecall 0x012
 472          li16 x3, score
 473          lw a0, 0(x3)
 474          ecall 0x000
 475          li a0, 10
 476          ecall 0x001
 477          ecall 0x3FF
 478      
 479      .data
 480      length:           .word 4
 481      direction:        .word 1
 482      pending_head:     .word 151
 483      next_food_offset: .word 72
 484      score:            .word 0
 485      food0:            .word 170
 486      food1:            .word 207
 487      food2:            .word 228
 488      segments:         .space 64
 489      game_over_text:   .string "GAME OVER  SCORE: "

