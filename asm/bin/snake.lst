ZX16 Assembler Listing
==================================================

   1      # ZX16 Snake
   2      # Controls: Up/Down/Left/Right or W/A/S/D
   3      # Tile map: 0xF000, 20 x 15
   4      # Tile IDs: 0 empty, 1 snake, 2 food, 3 wall
   5      
   6      .text
   7      
   8      start:
   9          # Palette
  10          li16 x3, 0xFA00
  11          li x4, 0x00
  12          sb x4, 0(x3)
  13          li x4, 0x1C
  14          sb x4, 1(x3)
  15          li x4, 0xE0
  16          sb x4, 2(x3)
  17          li x4, 0xFF
  18          sb x4, 3(x3)
  19      
  20          # Tile 0: empty
  21          li16 x3, 0xF200
  22          li16 x4, 128
  23          li x5, 0
  24      fill_tile0:
  25          sb x5, 0(x3)
  26          addi x3, 1
  27          dec x4
  28          bnz x4, fill_tile0
  29      
  30          # Tile 1: snake, full green block
  31          li16 x4, 128
  32          li x5, 0x11
  33      fill_tile1:
  34          sb x5, 0(x3)
  35          addi x3, 1
  36          dec x4
  37          bnz x4, fill_tile1
  38      
  39          # Tile 2: apple, smaller red center
  40          li16 x4, 128
  41          li x5, 0
  42      fill_tile2:
  43          sb x5, 0(x3)
  44          addi x3, 1
  45          dec x4
  46          bnz x4, fill_tile2
  47      
  48          li16 x3, 0xF304
  49          li x4, 8
  50          li x5, 0x22
  51      food_tile_rows:
  52          sb x5, -2(x3)
  53          sb x5, -1(x3)
  54          sb x5, 0(x3)
  55          sb x5, 1(x3)
  56          addi x3, 8
  57          dec x4
  58          bnz x4, food_tile_rows
  59      
  60          # Tile 3: wall
  61          li16 x3, 0xF380
  62          li16 x4, 128
  63          li x5, 0x33
  64      fill_tile3:
  65          sb x5, 0(x3)
  66          addi x3, 1
  67          dec x4
  68          bnz x4, fill_tile3
  69      
  70          # Clear map
  71          li16 x3, 0xF000
  72          li16 x4, 300
  73          li x5, 0
  74      clear_map:
  75          sb x5, 0(x3)
  76          addi x3, 1
  77          dec x4
  78          bnz x4, clear_map
  79      
  80          # Horizontal walls
  81          li16 x3, 0xF000
  82          li16 x6, 0xF118
  83          li x4, 20
  84          li x5, 3
  85      wall_top_bottom:
  86          sb x5, 0(x3)
  87          sb x5, 0(x6)
  88          addi x3, 1
  89          addi x6, 1
  90          dec x4
  91          bnz x4, wall_top_bottom
  92      
  93          # Vertical walls
  94          li16 x3, 0xF000
  95          li x4, 15
  96      wall_sides:
  97          sb x5, 0(x3)
  98          mv x6, x3
  99          addi x6, 19
 100          sb x5, 0(x6)
 101          addi x3, 20
 102          dec x4
 103          bnz x4, wall_sides
 104      
 105          # Initial body: offsets 148,149,150,151
 106          li16 x3, segments
 107          li16 x4, 148
 108          sw x4, 0(x3)
 109          li16 x4, 149
 110          sw x4, 2(x3)
 111          li16 x4, 150
 112          sw x4, 4(x3)
 113          li16 x4, 151
 114          sw x4, 6(x3)
 115      
 116          li16 x3, length
 117          li x4, 4
 118          sw x4, 0(x3)
 119      
 120          li16 x3, direction
 121          li x4, 1
 122          sw x4, 0(x3)
 123      
 124          li16 x3, next_food_offset
 125          li x4, 72
 126          sw x4, 0(x3)
 127      
 128          li16 x3, score
 129          li x4, 0
 130          sw x4, 0(x3)
 131      
 132          li16 x3, food0
 133          li16 x4, 170
 134          sw x4, 0(x3)
 135      
 136          li16 x3, food1
 137          li16 x4, 207
 138          sw x4, 0(x3)
 139      
 140          li16 x3, food2
 141          li16 x4, 228
 142          sw x4, 0(x3)
 143      
 144          # Initial draw. After this, wait for the first key press.
 145          li x4, 2
 146          li16 x3, 0xF0AA
 147          sb x4, 0(x3)
 148          li16 x3, 0xF0CF
 149          sb x4, 0(x3)
 150          li16 x3, 0xF0E4
 151          sb x4, 0(x3)
 152      
 153          li x4, 1
 154          li16 x3, 0xF094
 155          sb x4, 0(x3)
 156          sb x4, 1(x3)
 157          sb x4, 2(x3)
 158          sb x4, 3(x3)
 159      
 160      wait_for_start:
 161          ecall 0x030
 162          li x5, 1
 163          beq a0, x5, start_game
 164          li x5, 2
 165          beq a0, x5, start_game
 166          li x5, 3
 167          beq a0, x5, start_game
 168          li x5, 4
 169          beq a0, x5, start_game
 170          j wait_for_start
 171      
 172      start_game:
 173          j input_ready
 174      
 175      game_loop:
 176          li16 x3, 3000
 177      delay_loop:
 178          dec x3
 179          bnz x3, delay_loop
 180      
 181          ecall 0x030
 182      
 183      input_ready:
 184          li x5, 1
 185          beq a0, x5, set_up
 186          j check_down
 187      set_up:
 188          li16 x3, direction
 189          lw x6, 0(x3)
 190          li x5, 20
 191          bne x6, x5, set_up_apply
 192          j direction_done
 193      set_up_apply:
 194          li x4, -20
 195          sw x4, 0(x3)
 196          j direction_done
 197      
 198      check_down:
 199          li x5, 2
 200          beq a0, x5, set_down
 201          j check_left
 202      set_down:
 203          li16 x3, direction
 204          lw x6, 0(x3)
 205          li x5, -20
 206          bne x6, x5, set_down_apply
 207          j direction_done
 208      set_down_apply:
 209          li x4, 20
 210          sw x4, 0(x3)
 211          j direction_done
 212      
 213      check_left:
 214          li x5, 3
 215          beq a0, x5, set_left
 216          j check_right
 217      set_left:
 218          li16 x3, direction
 219          lw x6, 0(x3)
 220          li x5, 1
 221          bne x6, x5, set_left_apply
 222          j direction_done
 223      set_left_apply:
 224          li x4, -1
 225          sw x4, 0(x3)
 226          j direction_done
 227      
 228      check_right:
 229          li x5, 4
 230          beq a0, x5, set_right
 231          j direction_done
 232      set_right:
 233          li16 x3, direction
 234          lw x6, 0(x3)
 235          li x5, -1
 236          bne x6, x5, set_right_apply
 237          j direction_done
 238      set_right_apply:
 239          li x4, 1
 240          sw x4, 0(x3)
 241      
 242      direction_done:
 243          # x4 = new head offset
 244          li16 x3, length
 245          lw x5, 0(x3)
 246          dec x5
 247          slli x5, 1
 248          li16 x3, segments
 249          add x3, x5
 250          lw x4, 0(x3)
 251      
 252          li16 x3, direction
 253          lw x5, 0(x3)
 254          add x4, x5
 255      
 256          li16 x3, pending_head
 257          sw x4, 0(x3)
 258      
 259          li16 x3, 0xF000
 260          add x3, x4
 261          lbu x5, 0(x3)
 262      
 263          li x6, 0
 264          bne x5, x6, check_food
 265          j normal_move
 266      
 267      check_food:
 268          li x6, 2
 269          bne x5, x6, check_snake
 270          j eat_food
 271      
 272      check_snake:
 273          li x6, 1
 274          beq x5, x6, snake_tile
 275          j game_over
 276      snake_tile:
 277          li16 x3, segments
 278          lw x6, 0(x3)
 279          beq x4, x6, tail_tile
 280          j game_over
 281      tail_tile:
 282          j normal_move
 283      
 284      normal_move:
 285          # Erase old tail.
 286          li16 x3, segments
 287          lw x4, 0(x3)
 288          li16 x3, 0xF000
 289          add x3, x4
 290          li x5, 0
 291          sb x5, 0(x3)
 292      
 293          # Shift body one slot toward the tail.
 294          li16 x3, length
 295          lw x5, 0(x3)
 296          dec x5
 297          li16 x3, segments
 298      shift_loop:
 299          mv x6, x3
 300          addi x6, 2
 301          lw a1, 0(x6)
 302          sw a1, 0(x3)
 303          addi x3, 2
 304          dec x5
 305          bnz x5, shift_loop
 306      
 307          # Store new head in the last slot.
 308          li16 x3, length
 309          lw x5, 0(x3)
 310          dec x5
 311          slli x5, 1
 312          li16 x3, segments
 313          add x3, x5
 314          li16 x4, pending_head
 315          lw x4, 0(x4)
 316          sw x4, 0(x3)
 317          j draw_head
 318      
 319      eat_food:
 320          # Append a new head and increase length, up to 24 cells.
 321          li16 x3, length
 322          lw x5, 0(x3)
 323          li x6, 24
 324          bltu x5, x6, grow_body
 325          j normal_move
 326      
 327      grow_body:
 328          mv x6, x5
 329          slli x6, 1
 330          li16 x3, segments
 331          add x3, x6
 332          li16 x4, pending_head
 333          lw x4, 0(x4)
 334          sw x4, 0(x3)
 335      
 336          inc x5
 337          li16 x3, length
 338          sw x5, 0(x3)
 339      
 340          li16 x3, score
 341          lw x5, 0(x3)
 342          inc x5
 343          sw x5, 0(x3)
 344      
 345          j draw_head_after_food
 346      
 347      draw_head:
 348          li16 x3, pending_head
 349          lw x4, 0(x3)
 350          li16 x3, 0xF000
 351          add x3, x4
 352          li x5, 1
 353          sb x5, 0(x3)
 354          j game_loop
 355      
 356      draw_head_after_food:
 357          li16 x3, pending_head
 358          lw x4, 0(x3)
 359          li16 x3, 0xF000
 360          add x3, x4
 361          li x5, 1
 362          sb x5, 0(x3)
 363          j food_next
 364      
 365      food_next:
 366          li16 x3, next_food_offset
 367          lw x4, 0(x3)
 368          addi x4, 37
 369      
 370          li16 x5, 260
 371          bltu x4, x5, food_try
 372          j food_wrap
 373      
 374      food_wrap:
 375          li x4, 42
 376      
 377      food_try:
 378          li16 x3, 0xF000
 379          add x3, x4
 380          lbu x5, 0(x3)
 381          li x6, 0
 382          beq x5, x6, food_place
 383          j food_advance
 384      
 385      food_advance:
 386          addi x4, 37
 387          li16 x5, 260
 388          bltu x4, x5, food_try
 389          j food_wrap
 390      
 391      food_place:
 392          li16 x3, pending_head
 393          lw x5, 0(x3)
 394      
 395          li16 x3, food0
 396          lw x6, 0(x3)
 397          beq x5, x6, replace_food0
 398          j check_replace_food1
 399      
 400      replace_food0:
 401          sw x4, 0(x3)
 402          j save_next_food
 403      
 404      check_replace_food1:
 405          li16 x3, food1
 406          lw x6, 0(x3)
 407          beq x5, x6, replace_food1
 408          j replace_food2
 409      
 410      replace_food1:
 411          sw x4, 0(x3)
 412          j save_next_food
 413      
 414      replace_food2:
 415          li16 x3, food2
 416          sw x4, 0(x3)
 417      
 418      save_next_food:
 419          li16 x3, next_food_offset
 420          sw x4, 0(x3)
 421          li16 x3, 0xF000
 422          add x3, x4
 423          li x5, 2
 424          sb x5, 0(x3)
 425          j game_loop
 426      
 427      game_over:
 428          li16 a0, game_over_text
 429          ecall 0x012
 430          li16 x3, score
 431          lw a0, 0(x3)
 432          ecall 0x000
 433          li a0, 10
 434          ecall 0x001
 435          ecall 0x3FF
 436      
 437      .data
 438      length:           .word 4
 439      direction:        .word 1
 440      pending_head:     .word 151
 441      next_food_offset: .word 72
 442      score:            .word 0
 443      food0:            .word 170
 444      food1:            .word 207
 445      food2:            .word 228
 446      segments:         .space 64
 447      game_over_text:   .string "GAME OVER  SCORE: "

