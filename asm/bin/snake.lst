ZX16 Assembler Listing
==================================================

   1      # ZX16 Snake
   2      # Controls: Up/Down/Left/Right or W/A/S/D
   3      # Tile map: 0xF000, 20 x 15
   4      # Tile IDs: 0 empty, 1 snake, 2 food, 3 wall
   5      
   6      .text
   7      
   8      start:
   9          li16 sp, 0xEFFE
  10      
  11          li a0, 35
  12          ecall 0x041
  13      
  14          # Palette
  15          li16 x3, 0xFA00
  16          li x4, 0x00
  17          sb x4, 0(x3)
  18          li x4, 0x1C
  19          sb x4, 1(x3)
  20          li x4, 0xE0
  21          sb x4, 2(x3)
  22          li x4, 0xFF
  23          sb x4, 3(x3)
  24      
  25          # Tile 0: empty
  26          li16 x3, 0xF200
  27          li16 x4, 128
  28          li x5, 0
  29      fill_tile0:
  30          sb x5, 0(x3)
  31          addi x3, 1
  32          dec x4
  33          bnz x4, fill_tile0
  34      
  35          # Tile 1: snake, full green block
  36          li16 x4, 128
  37          li x5, 0x11
  38      fill_tile1:
  39          sb x5, 0(x3)
  40          addi x3, 1
  41          dec x4
  42          bnz x4, fill_tile1
  43      
  44          # Tile 2: apple, smaller red center
  45          li16 x4, 128
  46          li x5, 0
  47      fill_tile2:
  48          sb x5, 0(x3)
  49          addi x3, 1
  50          dec x4
  51          bnz x4, fill_tile2
  52      
  53          li16 x3, 0xF304
  54          li x4, 8
  55          li x5, 0x22
  56      food_tile_rows:
  57          sb x5, -2(x3)
  58          sb x5, -1(x3)
  59          sb x5, 0(x3)
  60          sb x5, 1(x3)
  61          addi x3, 8
  62          dec x4
  63          bnz x4, food_tile_rows
  64      
  65          # Tile 3: wall
  66          li16 x3, 0xF380
  67          li16 x4, 128
  68          li x5, 0x33
  69      fill_tile3:
  70          sb x5, 0(x3)
  71          addi x3, 1
  72          dec x4
  73          bnz x4, fill_tile3
  74      
  75          # Clear map
  76          li16 x3, 0xF000
  77          li16 x4, 300
  78          li x5, 0
  79      clear_map:
  80          sb x5, 0(x3)
  81          addi x3, 1
  82          dec x4
  83          bnz x4, clear_map
  84      
  85          # Horizontal walls
  86          li16 x3, 0xF000
  87          li16 x6, 0xF118
  88          li x4, 20
  89          li x5, 3
  90      wall_top_bottom:
  91          sb x5, 0(x3)
  92          sb x5, 0(x6)
  93          addi x3, 1
  94          addi x6, 1
  95          dec x4
  96          bnz x4, wall_top_bottom
  97      
  98          # Vertical walls
  99          li16 x3, 0xF000
 100          li x4, 15
 101      wall_sides:
 102          sb x5, 0(x3)
 103          mv x6, x3
 104          addi x6, 19
 105          sb x5, 0(x6)
 106          addi x3, 20
 107          dec x4
 108          bnz x4, wall_sides
 109      
 110          # Initial body: offsets 148,149,150,151
 111          li16 x3, segments
 112          li16 x4, 148
 113          sw x4, 0(x3)
 114          li16 x4, 149
 115          sw x4, 2(x3)
 116          li16 x4, 150
 117          sw x4, 4(x3)
 118          li16 x4, 151
 119          sw x4, 6(x3)
 120      
 121          li16 x3, length
 122          li x4, 4
 123          sw x4, 0(x3)
 124      
 125          li16 x3, direction
 126          li x4, 1
 127          sw x4, 0(x3)
 128      
 129          li16 x3, next_food_offset
 130          li x4, 72
 131          sw x4, 0(x3)
 132      
 133          li16 x3, score
 134          li x4, 0
 135          sw x4, 0(x3)
 136      
 137          # Initial snake draw.
 138          li x4, 1
 139          li16 x3, 0xF094
 140          sb x4, 0(x3)
 141          sb x4, 1(x3)
 142          sb x4, 2(x3)
 143          sb x4, 3(x3)
 144      
 145      init_food0:
 146          ecall 0x021
 147          li16 x3, rng_byte
 148          sb a0, 0(x3)
 149          lbu x4, 0(x3)
 150          j init_food0_try
 151      init_food0_try:
 152          li16 x3, 0xF000
 153          add x3, x4
 154          lbu x5, 0(x3)
 155          li x6, 0
 156          beq x5, x6, init_food0_place
 157          addi x4, 1
 158          li16 x5, 300
 159          bltu x4, x5, init_food0_loop
 160          li x4, 0
 161      init_food0_loop:
 162          j init_food0_try
 163      init_food0_place:
 164          li16 x3, food0
 165          sw x4, 0(x3)
 166          li16 x3, 0xF000
 167          add x3, x4
 168          li x5, 2
 169          sb x5, 0(x3)
 170      
 171      init_food1:
 172          ecall 0x021
 173          li16 x3, rng_byte
 174          sb a0, 0(x3)
 175          lbu x4, 0(x3)
 176          j init_food1_try
 177      init_food1_try:
 178          li16 x3, 0xF000
 179          add x3, x4
 180          lbu x5, 0(x3)
 181          li x6, 0
 182          beq x5, x6, init_food1_place
 183          addi x4, 1
 184          li16 x5, 300
 185          bltu x4, x5, init_food1_loop
 186          li x4, 0
 187      init_food1_loop:
 188          j init_food1_try
 189      init_food1_place:
 190          li16 x3, food1
 191          sw x4, 0(x3)
 192          li16 x3, 0xF000
 193          add x3, x4
 194          li x5, 2
 195          sb x5, 0(x3)
 196      
 197      init_food2:
 198          ecall 0x021
 199          li16 x3, rng_byte
 200          sb a0, 0(x3)
 201          lbu x4, 0(x3)
 202          j init_food2_try
 203      init_food2_try:
 204          li16 x3, 0xF000
 205          add x3, x4
 206          lbu x5, 0(x3)
 207          li x6, 0
 208          beq x5, x6, init_food2_place
 209          addi x4, 1
 210          li16 x5, 300
 211          bltu x4, x5, init_food2_loop
 212          li x4, 0
 213      init_food2_loop:
 214          j init_food2_try
 215      init_food2_place:
 216          li16 x3, food2
 217          sw x4, 0(x3)
 218          li16 x3, 0xF000
 219          add x3, x4
 220          li x5, 2
 221          sb x5, 0(x3)
 222      
 223          # After this, wait for the first key press.
 224      wait_for_start:
 225          ecall 0x030
 226          li x5, 1
 227          beq a0, x5, start_game
 228          li x5, 2
 229          beq a0, x5, start_game
 230          li x5, 3
 231          beq a0, x5, start_game
 232          li x5, 4
 233          beq a0, x5, start_game
 234          j wait_for_start
 235      
 236      start_game:
 237          j input_ready
 238      
 239      game_loop:
 240          li16 x3, 3000
 241      delay_loop:
 242          dec x3
 243          bnz x3, delay_loop
 244      
 245          ecall 0x030
 246      
 247      input_ready:
 248          li x5, 1
 249          beq a0, x5, set_up
 250          j check_down
 251      set_up:
 252          li16 x3, direction
 253          lw x6, 0(x3)
 254          li x5, 20
 255          bne x6, x5, set_up_apply
 256          j direction_done
 257      set_up_apply:
 258          li x4, -20
 259          sw x4, 0(x3)
 260          j direction_done
 261      
 262      check_down:
 263          li x5, 2
 264          beq a0, x5, set_down
 265          j check_left
 266      set_down:
 267          li16 x3, direction
 268          lw x6, 0(x3)
 269          li x5, -20
 270          bne x6, x5, set_down_apply
 271          j direction_done
 272      set_down_apply:
 273          li x4, 20
 274          sw x4, 0(x3)
 275          j direction_done
 276      
 277      check_left:
 278          li x5, 3
 279          beq a0, x5, set_left
 280          j check_right
 281      set_left:
 282          li16 x3, direction
 283          lw x6, 0(x3)
 284          li x5, 1
 285          bne x6, x5, set_left_apply
 286          j direction_done
 287      set_left_apply:
 288          li x4, -1
 289          sw x4, 0(x3)
 290          j direction_done
 291      
 292      check_right:
 293          li x5, 4
 294          beq a0, x5, set_right
 295          j direction_done
 296      set_right:
 297          li16 x3, direction
 298          lw x6, 0(x3)
 299          li x5, -1
 300          bne x6, x5, set_right_apply
 301          j direction_done
 302      set_right_apply:
 303          li x4, 1
 304          sw x4, 0(x3)
 305      
 306      direction_done:
 307          # x4 = new head offset
 308          li16 x3, length
 309          lw x5, 0(x3)
 310          dec x5
 311          slli x5, 1
 312          li16 x3, segments
 313          add x3, x5
 314          lw x4, 0(x3)
 315      
 316          li16 x3, direction
 317          lw x5, 0(x3)
 318          add x4, x5
 319      
 320          li16 x3, pending_head
 321          sw x4, 0(x3)
 322      
 323          li16 x3, 0xF000
 324          add x3, x4
 325          lbu x5, 0(x3)
 326      
 327          li x6, 0
 328          bne x5, x6, check_food
 329          j normal_move
 330      
 331      check_food:
 332          li x6, 2
 333          bne x5, x6, check_snake
 334          j eat_food
 335      
 336      check_snake:
 337          li x6, 1
 338          beq x5, x6, snake_tile
 339          j game_over
 340      snake_tile:
 341          li16 x3, segments
 342          lw x6, 0(x3)
 343          beq x4, x6, tail_tile
 344          j game_over
 345      tail_tile:
 346          j normal_move
 347      
 348      normal_move:
 349          # Erase old tail.
 350          li16 x3, segments
 351          lw x4, 0(x3)
 352          li16 x3, 0xF000
 353          add x3, x4
 354          li x5, 0
 355          sb x5, 0(x3)
 356      
 357          # Shift body one slot toward the tail.
 358          li16 x3, length
 359          lw x5, 0(x3)
 360          dec x5
 361          li16 x3, segments
 362      shift_loop:
 363          mv x6, x3
 364          addi x6, 2
 365          lw a1, 0(x6)
 366          sw a1, 0(x3)
 367          addi x3, 2
 368          dec x5
 369          bnz x5, shift_loop
 370      
 371          # Store new head in the last slot.
 372          li16 x3, length
 373          lw x5, 0(x3)
 374          dec x5
 375          slli x5, 1
 376          li16 x3, segments
 377          add x3, x5
 378          li16 x4, pending_head
 379          lw x4, 0(x4)
 380          sw x4, 0(x3)
 381          j draw_head
 382      
 383      eat_food:
 384          # Append a new head and increase length, up to 80 cells.
 385          li16 x3, length
 386          lw x5, 0(x3)
 387          li16 x6, 80
 388          bltu x5, x6, grow_body
 389          j max_length_food_move
 390      
 391      grow_body:
 392          mv x6, x5
 393          slli x6, 1
 394          li16 x3, segments
 395          add x3, x6
 396          li16 x4, pending_head
 397          lw x4, 0(x4)
 398          sw x4, 0(x3)
 399      
 400          inc x5
 401          li16 x3, length
 402          sw x5, 0(x3)
 403      
 404          li16 a0, 880
 405          li16 a1, 90
 406          ecall 0x040
 407      
 408          li16 x3, score
 409          lw x5, 0(x3)
 410          addi x5, 5
 411          sw x5, 0(x3)
 412      
 413          j draw_head_after_food
 414      
 415      max_length_food_move:
 416          # At max length, still move forward and replace the eaten apple.
 417          li16 x3, segments
 418          lw x4, 0(x3)
 419          li16 x3, 0xF000
 420          add x3, x4
 421          li x5, 0
 422          sb x5, 0(x3)
 423      
 424          li16 x3, length
 425          lw x5, 0(x3)
 426          dec x5
 427          li16 x3, segments
 428      max_food_shift_loop:
 429          mv x6, x3
 430          addi x6, 2
 431          lw a1, 0(x6)
 432          sw a1, 0(x3)
 433          addi x3, 2
 434          dec x5
 435          bnz x5, max_food_shift_loop
 436      
 437          li16 x3, length
 438          lw x5, 0(x3)
 439          dec x5
 440          slli x5, 1
 441          li16 x3, segments
 442          add x3, x5
 443          li16 x4, pending_head
 444          lw x4, 0(x4)
 445          sw x4, 0(x3)
 446      
 447          li16 a0, 880
 448          li16 a1, 90
 449          ecall 0x040
 450      
 451          li16 x3, score
 452          lw x5, 0(x3)
 453          addi x5, 5
 454          sw x5, 0(x3)
 455      
 456          j draw_head_after_food
 457      
 458      draw_head:
 459          li16 x3, pending_head
 460          lw x4, 0(x3)
 461          li16 x3, 0xF000
 462          add x3, x4
 463          li x5, 1
 464          sb x5, 0(x3)
 465          j game_loop
 466      
 467      draw_head_after_food:
 468          li16 x3, pending_head
 469          lw x4, 0(x3)
 470          li16 x3, 0xF000
 471          add x3, x4
 472          li x5, 1
 473          sb x5, 0(x3)
 474          j food_next
 475      
 476      food_next:
 477          ecall 0x021
 478          li16 x3, rng_byte
 479          sb a0, 0(x3)
 480          lbu x4, 0(x3)
 481          j food_try
 482      
 483      food_wrap:
 484          li x4, 0
 485      
 486      food_try:
 487          li16 x3, 0xF000
 488          add x3, x4
 489          lbu x5, 0(x3)
 490          li x6, 0
 491          beq x5, x6, food_place
 492          j food_advance
 493      
 494      food_advance:
 495          addi x4, 1
 496          li16 x5, 300
 497          bltu x4, x5, food_advance_try
 498          j food_wrap
 499      
 500      food_advance_try:
 501          j food_try
 502      
 503      food_place:
 504          li16 x3, pending_head
 505          lw x5, 0(x3)
 506      
 507          li16 x3, food0
 508          lw x6, 0(x3)
 509          beq x5, x6, replace_food0
 510          j check_replace_food1
 511      
 512      replace_food0:
 513          sw x4, 0(x3)
 514          j save_next_food
 515      
 516      check_replace_food1:
 517          li16 x3, food1
 518          lw x6, 0(x3)
 519          beq x5, x6, replace_food1
 520          j replace_food2
 521      
 522      replace_food1:
 523          sw x4, 0(x3)
 524          j save_next_food
 525      
 526      replace_food2:
 527          li16 x3, food2
 528          sw x4, 0(x3)
 529      
 530      save_next_food:
 531          li16 x3, next_food_offset
 532          sw x4, 0(x3)
 533          li16 x3, 0xF000
 534          add x3, x4
 535          li x5, 2
 536          sb x5, 0(x3)
 537          li16 x3, game_loop
 538          jr x3
 539      
 540      game_over:
 541          li16 a0, 180
 542          li16 a1, 700
 543          ecall 0x040
 544      
 545          li16 a0, game_over_text
 546          ecall 0x012
 547          li16 x3, score
 548          lw a0, 0(x3)
 549          ecall 0x000
 550          li a0, 10
 551          ecall 0x001
 552          ecall 0x3FF
 553      
 554      .data
 555      length:           .word 4
 556      direction:        .word 1
 557      pending_head:     .word 151
 558      next_food_offset: .word 72
 559      score:            .word 0
 560      food0:            .word 0
 561      food1:            .word 0
 562      food2:            .word 0
 563      rng_byte:         .word 0
 564      segments:         .space 160
 565      game_over_text:   .string "GAME OVER  SCORE: "

