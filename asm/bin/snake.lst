ZX16 Assembler Listing
==================================================

   1      # ZX16 Snake
   2      # Controls: Up/Down/Left/Right or W/A/S/D
   3      # Tile map: 0xF000, 20 x 15
   4      # Tile IDs: 0 empty, 1 snake, 2 food, 3 wall
   5      
   6      .text
   7      
   8      start:
   9          li16 sp, 0xEFFE
  10      
  11          # Palette
  12          li16 x3, 0xFA00
  13          li x4, 0x00
  14          sb x4, 0(x3)
  15          li x4, 0x1C
  16          sb x4, 1(x3)
  17          li x4, 0xE0
  18          sb x4, 2(x3)
  19          li x4, 0xFF
  20          sb x4, 3(x3)
  21      
  22          # Tile 0: empty
  23          li16 x3, 0xF200
  24          li16 x4, 128
  25          li x5, 0
  26      fill_tile0:
  27          sb x5, 0(x3)
  28          addi x3, 1
  29          dec x4
  30          bnz x4, fill_tile0
  31      
  32          # Tile 1: snake, full green block
  33          li16 x4, 128
  34          li x5, 0x11
  35      fill_tile1:
  36          sb x5, 0(x3)
  37          addi x3, 1
  38          dec x4
  39          bnz x4, fill_tile1
  40      
  41          # Tile 2: apple, smaller red center
  42          li16 x4, 128
  43          li x5, 0
  44      fill_tile2:
  45          sb x5, 0(x3)
  46          addi x3, 1
  47          dec x4
  48          bnz x4, fill_tile2
  49      
  50          li16 x3, 0xF304
  51          li x4, 8
  52          li x5, 0x22
  53      food_tile_rows:
  54          sb x5, -2(x3)
  55          sb x5, -1(x3)
  56          sb x5, 0(x3)
  57          sb x5, 1(x3)
  58          addi x3, 8
  59          dec x4
  60          bnz x4, food_tile_rows
  61      
  62          # Tile 3: wall
  63          li16 x3, 0xF380
  64          li16 x4, 128
  65          li x5, 0x33
  66      fill_tile3:
  67          sb x5, 0(x3)
  68          addi x3, 1
  69          dec x4
  70          bnz x4, fill_tile3
  71      
  72          # Clear map
  73          li16 x3, 0xF000
  74          li16 x4, 300
  75          li x5, 0
  76      clear_map:
  77          sb x5, 0(x3)
  78          addi x3, 1
  79          dec x4
  80          bnz x4, clear_map
  81      
  82          # Horizontal walls
  83          li16 x3, 0xF000
  84          li16 x6, 0xF118
  85          li x4, 20
  86          li x5, 3
  87      wall_top_bottom:
  88          sb x5, 0(x3)
  89          sb x5, 0(x6)
  90          addi x3, 1
  91          addi x6, 1
  92          dec x4
  93          bnz x4, wall_top_bottom
  94      
  95          # Vertical walls
  96          li16 x3, 0xF000
  97          li x4, 15
  98      wall_sides:
  99          sb x5, 0(x3)
 100          mv x6, x3
 101          addi x6, 19
 102          sb x5, 0(x6)
 103          addi x3, 20
 104          dec x4
 105          bnz x4, wall_sides
 106      
 107          # Initial body: offsets 148,149,150,151
 108          li16 x3, segments
 109          li16 x4, 148
 110          sw x4, 0(x3)
 111          li16 x4, 149
 112          sw x4, 2(x3)
 113          li16 x4, 150
 114          sw x4, 4(x3)
 115          li16 x4, 151
 116          sw x4, 6(x3)
 117      
 118          li16 x3, length
 119          li x4, 4
 120          sw x4, 0(x3)
 121      
 122          li16 x3, direction
 123          li x4, 1
 124          sw x4, 0(x3)
 125      
 126          li16 x3, next_food_offset
 127          li x4, 72
 128          sw x4, 0(x3)
 129      
 130          li16 x3, score
 131          li x4, 0
 132          sw x4, 0(x3)
 133      
 134          li16 x3, food0
 135          li16 x4, 170
 136          sw x4, 0(x3)
 137      
 138          li16 x3, food1
 139          li16 x4, 207
 140          sw x4, 0(x3)
 141      
 142          li16 x3, food2
 143          li16 x4, 228
 144          sw x4, 0(x3)
 145      
 146          # Initial draw. After this, wait for the first key press.
 147          li x4, 2
 148          li16 x3, 0xF0AA
 149          sb x4, 0(x3)
 150          li16 x3, 0xF0CF
 151          sb x4, 0(x3)
 152          li16 x3, 0xF0E4
 153          sb x4, 0(x3)
 154      
 155          li x4, 1
 156          li16 x3, 0xF094
 157          sb x4, 0(x3)
 158          sb x4, 1(x3)
 159          sb x4, 2(x3)
 160          sb x4, 3(x3)
 161      
 162      wait_for_start:
 163          ecall 0x030
 164          li x5, 1
 165          beq a0, x5, start_game
 166          li x5, 2
 167          beq a0, x5, start_game
 168          li x5, 3
 169          beq a0, x5, start_game
 170          li x5, 4
 171          beq a0, x5, start_game
 172          j wait_for_start
 173      
 174      start_game:
 175          j input_ready
 176      
 177      game_loop:
 178          li16 x3, 3000
 179      delay_loop:
 180          dec x3
 181          bnz x3, delay_loop
 182      
 183          ecall 0x030
 184      
 185      input_ready:
 186          li x5, 1
 187          beq a0, x5, set_up
 188          j check_down
 189      set_up:
 190          li16 x3, direction
 191          lw x6, 0(x3)
 192          li x5, 20
 193          bne x6, x5, set_up_apply
 194          j direction_done
 195      set_up_apply:
 196          li x4, -20
 197          sw x4, 0(x3)
 198          j direction_done
 199      
 200      check_down:
 201          li x5, 2
 202          beq a0, x5, set_down
 203          j check_left
 204      set_down:
 205          li16 x3, direction
 206          lw x6, 0(x3)
 207          li x5, -20
 208          bne x6, x5, set_down_apply
 209          j direction_done
 210      set_down_apply:
 211          li x4, 20
 212          sw x4, 0(x3)
 213          j direction_done
 214      
 215      check_left:
 216          li x5, 3
 217          beq a0, x5, set_left
 218          j check_right
 219      set_left:
 220          li16 x3, direction
 221          lw x6, 0(x3)
 222          li x5, 1
 223          bne x6, x5, set_left_apply
 224          j direction_done
 225      set_left_apply:
 226          li x4, -1
 227          sw x4, 0(x3)
 228          j direction_done
 229      
 230      check_right:
 231          li x5, 4
 232          beq a0, x5, set_right
 233          j direction_done
 234      set_right:
 235          li16 x3, direction
 236          lw x6, 0(x3)
 237          li x5, -1
 238          bne x6, x5, set_right_apply
 239          j direction_done
 240      set_right_apply:
 241          li x4, 1
 242          sw x4, 0(x3)
 243      
 244      direction_done:
 245          # x4 = new head offset
 246          li16 x3, length
 247          lw x5, 0(x3)
 248          dec x5
 249          slli x5, 1
 250          li16 x3, segments
 251          add x3, x5
 252          lw x4, 0(x3)
 253      
 254          li16 x3, direction
 255          lw x5, 0(x3)
 256          add x4, x5
 257      
 258          li16 x3, pending_head
 259          sw x4, 0(x3)
 260      
 261          li16 x3, 0xF000
 262          add x3, x4
 263          lbu x5, 0(x3)
 264      
 265          li x6, 0
 266          bne x5, x6, check_food
 267          j normal_move
 268      
 269      check_food:
 270          li x6, 2
 271          bne x5, x6, check_snake
 272          j eat_food
 273      
 274      check_snake:
 275          li x6, 1
 276          beq x5, x6, snake_tile
 277          j game_over
 278      snake_tile:
 279          li16 x3, segments
 280          lw x6, 0(x3)
 281          beq x4, x6, tail_tile
 282          j game_over
 283      tail_tile:
 284          j normal_move
 285      
 286      normal_move:
 287          # Erase old tail.
 288          li16 x3, segments
 289          lw x4, 0(x3)
 290          li16 x3, 0xF000
 291          add x3, x4
 292          li x5, 0
 293          sb x5, 0(x3)
 294      
 295          # Shift body one slot toward the tail.
 296          li16 x3, length
 297          lw x5, 0(x3)
 298          dec x5
 299          li16 x3, segments
 300      shift_loop:
 301          mv x6, x3
 302          addi x6, 2
 303          lw a1, 0(x6)
 304          sw a1, 0(x3)
 305          addi x3, 2
 306          dec x5
 307          bnz x5, shift_loop
 308      
 309          # Store new head in the last slot.
 310          li16 x3, length
 311          lw x5, 0(x3)
 312          dec x5
 313          slli x5, 1
 314          li16 x3, segments
 315          add x3, x5
 316          li16 x4, pending_head
 317          lw x4, 0(x4)
 318          sw x4, 0(x3)
 319          j draw_head
 320      
 321      eat_food:
 322          # Append a new head and increase length, up to 24 cells.
 323          li16 x3, length
 324          lw x5, 0(x3)
 325          li x6, 24
 326          bltu x5, x6, grow_body
 327          j normal_move
 328      
 329      grow_body:
 330          mv x6, x5
 331          slli x6, 1
 332          li16 x3, segments
 333          add x3, x6
 334          li16 x4, pending_head
 335          lw x4, 0(x4)
 336          sw x4, 0(x3)
 337      
 338          inc x5
 339          li16 x3, length
 340          sw x5, 0(x3)
 341      
 342          li16 x3, score
 343          lw x5, 0(x3)
 344          inc x5
 345          sw x5, 0(x3)
 346      
 347          j draw_head_after_food
 348      
 349      draw_head:
 350          li16 x3, pending_head
 351          lw x4, 0(x3)
 352          li16 x3, 0xF000
 353          add x3, x4
 354          li x5, 1
 355          sb x5, 0(x3)
 356          j game_loop
 357      
 358      draw_head_after_food:
 359          li16 x3, pending_head
 360          lw x4, 0(x3)
 361          li16 x3, 0xF000
 362          add x3, x4
 363          li x5, 1
 364          sb x5, 0(x3)
 365          j food_next
 366      
 367      food_next:
 368          li16 x3, next_food_offset
 369          lw x4, 0(x3)
 370          addi x4, 37
 371      
 372          li16 x5, 260
 373          bltu x4, x5, food_try
 374          j food_wrap
 375      
 376      food_wrap:
 377          li x4, 42
 378      
 379      food_try:
 380          li16 x3, 0xF000
 381          add x3, x4
 382          lbu x5, 0(x3)
 383          li x6, 0
 384          beq x5, x6, food_place
 385          j food_advance
 386      
 387      food_advance:
 388          addi x4, 37
 389          li16 x5, 260
 390          bltu x4, x5, food_try
 391          j food_wrap
 392      
 393      food_place:
 394          li16 x3, pending_head
 395          lw x5, 0(x3)
 396      
 397          li16 x3, food0
 398          lw x6, 0(x3)
 399          beq x5, x6, replace_food0
 400          j check_replace_food1
 401      
 402      replace_food0:
 403          sw x4, 0(x3)
 404          j save_next_food
 405      
 406      check_replace_food1:
 407          li16 x3, food1
 408          lw x6, 0(x3)
 409          beq x5, x6, replace_food1
 410          j replace_food2
 411      
 412      replace_food1:
 413          sw x4, 0(x3)
 414          j save_next_food
 415      
 416      replace_food2:
 417          li16 x3, food2
 418          sw x4, 0(x3)
 419      
 420      save_next_food:
 421          li16 x3, next_food_offset
 422          sw x4, 0(x3)
 423          li16 x3, 0xF000
 424          add x3, x4
 425          li x5, 2
 426          sb x5, 0(x3)
 427          j game_loop
 428      
 429      game_over:
 430          li16 a0, game_over_text
 431          ecall 0x012
 432          li16 x3, score
 433          lw a0, 0(x3)
 434          ecall 0x000
 435          li a0, 10
 436          ecall 0x001
 437          ecall 0x3FF
 438      
 439      .data
 440      length:           .word 4
 441      direction:        .word 1
 442      pending_head:     .word 151
 443      next_food_offset: .word 72
 444      score:            .word 0
 445      food0:            .word 170
 446      food1:            .word 207
 447      food2:            .word 228
 448      segments:         .space 64
 449      game_over_text:   .string "GAME OVER  SCORE: "

